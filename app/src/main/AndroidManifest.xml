<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Notification permission — Android 13+ ke liye zaroori hai -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

       <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/splash_logo"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrizeBondTracker">
        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false" />
        <activity
            android:name=".BondDetailsActivity"
            android:exported="false" />
        <activity
            android:name=".BudgetSuggestionsActivity"
            android:exported="false" />
        <activity
            android:name=".WinningProbabilityActivity"
            android:exported="false" />
           <activity
               android:name=".NotificationActivity"
               android:exported="false" />
        <activity
            android:name=".item_draw_card"
            android:exported="false" />
        <activity
            android:name=".dialog_change_password"
            android:exported="false" />
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".UpcomingDrawsActivity"
            android:exported="false" />
        <activity
            android:name=".DrawResultsActivity"
            android:exported="false" />
        <activity
            android:name=".MyBondsActivity"
            android:exported="false" />
        <activity
            android:name=".AddBondActivity"
            android:exported="false" />
        <activity
            android:name=".HomeActivity"
            android:exported="false" />
        <activity
            android:name=".SignupActivity"
            android:exported="false" />
        <activity
            android:name=".LoginActivity"
            android:exported="false" />
        <activity
            android:name=".SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Application tag ke andar add karein -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>
    </application>

</manifest>