<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Active state: Use the primary green -->
    <item android:color="@color/primary_green" android:state_checked="true"/>
    <!-- Inactive state: Use a standard gray for inactive text/icons -->
    <item android:color="@color/text_secondary" android:state_checked="false"/>
</selector>