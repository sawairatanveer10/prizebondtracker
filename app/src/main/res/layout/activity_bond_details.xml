<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_green"
            app:title="Bond Details"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"/>

        <TextView
            android:id="@+id/tvBondNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bond: A-205001"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="16dp"/>

        <TextView
            android:id="@+id/tvDenomination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Denomination: Rs. 1500"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvDrawsChecked"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Draws Checked: 160"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvTimesWon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Historical Wins: 3"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="8dp"/>

                <TextView
            android:id="@+id/tvProbabilityPercentage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.0%"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/primary_green"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvProbabilityInterpretation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Low Probability"
            android:textSize="16sp"
            android:textStyle="italic"
            android:textColor="@color/text_primary"
            android:layout_marginTop="8dp"/>
    </LinearLayout>
</ScrollView>
