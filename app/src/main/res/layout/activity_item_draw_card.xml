<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left Side: Date and Denomination Highlight -->
        <!-- Use a specific color for the highlight area (e.g., a lighter green or blue) -->
        <LinearLayout
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:background="#4CAF50"> <!-- primary_green -->

            <!-- Month Abbreviation (e.g., NOV) -->
            <TextView
                android:id="@+id/tvDrawMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:textAllCaps="true"
                android:fontFamily="sans-serif-medium"
                tools:text="NOV"/>

            <!-- Day of Month (e.g., 15) -->
            <TextView
                android:id="@+id/tvDrawDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="32sp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                tools:text="15"/>

            <!-- Denomination Short Tag (e.g., Rs. 750) -->
            <TextView
                android:id="@+id/tvDenominationShort"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@android:color/white"
                            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:layout_marginTop="4dp"
            tools:text="Rs. 750"/>
        </LinearLayout>


        <!-- Right Side: Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Title: Bond Denomination -->
            <TextView
                android:id="@+id/tvDenominationFull"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textColor="#388E3C"             android:textStyle="bold"
            tools:text="Prize Bond Rs. 750"/>

            <!-- Draw Number & City Container -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <!-- Draw Number Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Draw No:"
                    android:textSize="14sp"
                    android:textColor="#757575"/> <!-- text_secondary -->
                <!-- Draw Number Value -->
                <TextView
                    android:id="@+id/tvDrawNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#212121"                 android:layout_marginStart="4dp"
                    android:fontFamily="sans-serif-medium"
                                    tools:text="98"/>

                <!-- City Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="City:"
                    android:textSize="14sp"
                    android:textColor="#757575"
                    android:layout_marginStart="16dp"/>
                <!-- City Value -->
                <TextView
                    android:id="@+id/tvDrawCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:layout_marginStart="4dp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="Karachi"/>
            </LinearLayout>

            <!-- Countdown/Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="0dp"
                android:paddingVertical="6dp"
                android:paddingHorizontal="16dp"
                android:text="25 Days Left"
                android:textSize="12sp"
                app:icon="@drawable/ic_noti"
            app:iconTint="@android:color/white"
            app:backgroundTint="#2196F3"
            app:cornerRadius="20dp"/>

        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
