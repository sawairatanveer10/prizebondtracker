<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    app:cardCornerRadius="16dp"
    app:cardElevation="16dp"
    android:layout_marginTop="8dp"
    android:background="@android:color/transparent"
    android:padding="0dp">

    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="483dp"
    android:background="@color/white"
    android:orientation="vertical"
    android:paddingBottom="8dp">
    <!-- Header (Optional) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@color/primary_green"
        android:paddingStart="20dp"
        android:paddingTop="12dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp"
        android:text="Navigation Menu"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold" />
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="8dp"
        android:background="@color/divider" />

    <!-- Menu Item 1: Add Bond -->
    <TextView
        android:id="@+id/menu_add_bond"
        style="@style/MenuItemText"
        android:drawableStart="@drawable/ic_add"
        android:text="Add Bond" />

    <!-- Menu Item 2: View Bond (My Bonds) -->
    <TextView
        android:id="@+id/menu_view_bonds"
        style="@style/MenuItemText"
        android:drawableStart="@drawable/ic_list"
        android:text="View Bond (My Bonds)" />

    <!-- Menu Item 3: Schedule -->
    <TextView
        android:id="@+id/menu_schedule"
        style="@style/MenuItemText"
        android:drawableStart="@drawable/ic_calender"
        android:text="Schedule (Upcoming Draws)" />
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@color/divider" />
    <!-- Menu Item 4: View Draw Results -->
    <TextView
        android:id="@+id/menu_view_results"
        style="@style/MenuItemText"
        android:drawableStart="@drawable/ic_result"
        android:text="View Draw Results" />
    <!-- Menu Item 5: View Winning Probability -->
    <TextView
        android:id="@+id/menu_view_probability"
        style="@style/MenuItemText"
        android:drawableStart="@drawable/ic_probability"
        android:text="View Winning Probability" />

    <!-- Menu Item 6: Purchasing Suggestions -->
    <TextView
        android:id="@+id/menu_purchasing_suggestions"
        style="@style/MenuItemText"
        android:drawableStart="@drawable/ic_bulb"
        android:text="Purchasing Suggestions" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@color/divider" />

    <!-- Menu Item 7: Logout -->
    <TextView
        android:id="@+id/menu_logout"
        style="@style/MenuItemText.Logout"
        android:drawableStart="@drawable/ic_logout"
        android:text="Logout" />

</LinearLayout>
</com.google.android.material.card.MaterialCardView>