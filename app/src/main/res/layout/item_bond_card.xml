<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Bond Number, Denomination, More/Edit Icon -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true">
                <!-- Bond Number -->
                <TextView
                    android:id="@+id/tvBondNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="A-123456"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>
                <!-- Purchase Date -->
                <TextView
                    android:id="@+id/tvPurchaseDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    tools:text="Purchased: 10/05/2023"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>

            <!-- Denomination Badge (Right Aligned) -->
            <TextView
                android:id="@+id/tvDenomination"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toStartOf="@id/btnMore"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/primary_green"
                android:background="@drawable/bg_denomination_badge"
                tools:text="Rs. 750"
                android:layout_marginEnd="8dp"
                android:layout_centerVertical="true"/>

            <!-- More Options Button -->
            <ImageButton
                android:id="@+id/btnMore"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:background="@null"
                android:src="@drawable/ic_more_ver"
                android:contentDescription="More options"
                app:tint="@color/text_secondary"
                android:layout_centerVertical="true"/>
        </RelativeLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"/>

        <!-- Bottom Row: Series and Draw City -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSeries"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Series: N/A"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"/>

            <TextView
                android:id="@+id/tvDrawCity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Draw City: N/A"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="end"/>
        </LinearLayout>


    </LinearLayout>
</androidx.cardview.widget.CardView>
