<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.PrizeBondTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary App Color (Deep Green) -->
        <item name="colorPrimary">@color/primary_green</item>
        <item name="colorPrimaryVariant">@color/primary_light</item>
        <item name="colorAccent">@color/primary_light</item>

        <!-- Status Bar & Navigation Bar: Clean White/Light Background -->
        <item name="android:statusBarColor">@color/primary_green</item>
        <item name="android:navigationBarColor">@color/white</item>

        <!-- Ensure dark icons in navigation bar, but status bar icons will be white against green -->
        <item name="android:windowLightStatusBar">false</item>


    </style>

    <style name="Theme.PrizeBondTracker" parent="Base.Theme.PrizeBondTracker" />
</resources>